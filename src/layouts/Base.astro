---
import pages from '../data/pages.json';

interface Props {
  title?: string;
  description?: string;
  wide?: boolean;
  explore?: boolean;
  frontmatter?: { title?: string; description?: string; explore?: boolean };
}

// Markdown pages pass title/description via frontmatter; .astro pages pass them directly
const fm = Astro.props.frontmatter ?? {};
const title = Astro.props.title ?? fm.title ?? 'vals.quest';
const description = Astro.props.description ?? fm.description ?? "Vals' personal website";
// `wide` lets a page (e.g. the travels globe) break out of the 800px column.
const wide = Astro.props.wide ?? false;
// `explore: true` appends the full site index (from pages.json) after the page body.
const explore = Astro.props.explore ?? fm.explore ?? false;

// src/data/pages.json is the single source of truth for internal links.
// `hidden: true` unlists a page (it still builds and works by direct URL);
// to un-publish entirely, rename the file in src/pages/ with a leading `_`.
const listed = pages.filter((p) => !p.hidden);
// Only pages with a `nav` label go in the header; the rest live in Explore only.
const navPages = listed.filter((p) => p.nav);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <nav>
      <a class="site-name" href="/">vals.quest</a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        {navPages.map((p) => <li><a href={p.href}>{p.nav}</a></li>)}
      </ul>
    </nav>
    <main class={wide ? 'wide' : undefined}>
      <slot />
      {explore && (
        <section class="explore">
          <h2>Explore</h2>
          <ul>
            {listed.map((p) => (
              <li><a href={p.href}>{p.label}</a> — {p.blurb}</li>
            ))}
          </ul>
        </section>
      )}
    </main>
    <footer>
      <ul class="contact-links">
        <li><a href="mailto:tutor.vals@gmail.com">email</a></li>
        <li><a href="https://x.com/TutorVals">Twitter</a></li>
        <li><a href="https://tutorvals.substack.com">Substack</a></li>
        <li><a href="https://www.lesswrong.com/users/tutor-vals">LessWrong</a></li>
      </ul>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
