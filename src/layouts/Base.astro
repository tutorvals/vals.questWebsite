---
interface Props {
  title?: string;
  description?: string;
  wide?: boolean;
  frontmatter?: { title?: string; description?: string };
}

// Markdown pages pass title/description via frontmatter; .astro pages pass them directly
const fm = Astro.props.frontmatter ?? {};
const title = Astro.props.title ?? fm.title ?? 'vals.quest';
const description = Astro.props.description ?? fm.description ?? "Vals' personal website";
// `wide` lets a page (e.g. the travels globe) break out of the 800px column.
const wide = Astro.props.wide ?? false;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <nav>
      <a class="site-name" href="/">vals.quest</a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/manifesto">Manifesto</a></li>
        <li><a href="/meet">Meet</a></li>
        <li><a href="/hireme">Hire</a></li>
        <li><a href="/activities">Activities</a></li>
        <li><a href="/conversations">Conversations</a></li>
        <li><a href="/travels">Travels</a></li>
      </ul>
    </nav>
    <main class={wide ? 'wide' : undefined}>
      <slot />
    </main>
    <footer>
      <ul class="contact-links">
        <li><a href="mailto:tutor.vals@gmail.com">email</a></li>
        <li><a href="https://x.com/TutorVals">Twitter</a></li>
        <li><a href="https://tutorvals.substack.com">Substack</a></li>
        <li><a href="https://www.lesswrong.com/users/tutor-vals">LessWrong</a></li>
      </ul>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
