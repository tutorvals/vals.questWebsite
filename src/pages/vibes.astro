---
import Base from '../layouts/Base.astro';
import vibes from '../data/vibes.json';
---

<Base
  title="Vibes - vals.quest"
  description="A random collage of images Vals vibes with."
  wide
>
  <div id="container"></div>

  <!-- Build-time manifest ([path, [w, h]] pairs), read at runtime below. -->
  <script
    type="application/json"
    id="vibes-data"
    set:html={JSON.stringify(vibes)}
    is:inline
  ></script>

  <script>
    // Ported (near) 1:1 from girl.surgery/website_vibes: shuffle, normalize every
    // image to roughly equal visual area, then randomly place each one where it
    // doesn't overlap an already-placed image, growing the canvas as needed.
    function shuffleArray(array) {
      for (let i = array.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [array[i], array[j]] = [array[j], array[i]];
      }
      return array;
    }

    const container = document.getElementById('container');
    const data = JSON.parse(document.getElementById('vibes-data').textContent);

    let key_values = shuffleArray([...data]);
    const rect = container.getBoundingClientRect();
    let screen_width = rect.width;

    // Resize the images to be approximately a similar size.
    const pairs = key_values
      .map(([, [w, h]]) => {
        let aspect_ratio = Math.max(w / h, h / w);
        let goal_pixels =
          aspect_ratio > 8 ? 200 * 200 : aspect_ratio > 4 ? 300 * 200 : 500 * 300;
        let actual_pixels = w * h;
        let adjustment_factor = Math.sqrt(actual_pixels / goal_pixels);
        return [parseInt(w / adjustment_factor), parseInt(h / adjustment_factor)];
      })
      .map(([w, h]) => [w + 10 > screen_width ? screen_width - 10 : w, h]);

    let positions = [];
    let i = 0;

    let interval = setInterval(() => {
      let height = 600;
      let [w, h] = pairs[i];

      while (1) {
        let found_place = false;
        let w_max = screen_width - w;
        let h_max = height - h;
        for (let k = 0; k < 50; k++) {
          let a_left = parseInt(Math.random() * w_max);
          let a_top = parseInt(Math.random() * h_max);
          let a_right = a_left + w;
          let a_bottom = a_top + h;

          let intersects = false;
          for (let j = 0; j < positions.length; j++) {
            let [b_left, b_top, other_w, other_h] = positions[j];
            let b_right = b_left + other_w;
            let b_bottom = b_top + other_h;
            if (
              a_left < b_right &&
              a_right > b_left &&
              a_bottom > b_top &&
              a_top < b_bottom
            ) {
              intersects = true;
              break;
            }
          }

          if (!intersects) {
            found_place = true;
            positions.push([parseInt(a_left), parseInt(a_top), w, h]);
            break;
          }
        }
        if (found_place) {
          break;
        } else {
          height += 50;
        }
      }

      let img = document.createElement('img');
      img.src = key_values[i][0];
      img.width = pairs[i][0];
      img.height = pairs[i][1];
      img.style.width = pairs[i][0] + 'px';
      img.style.height = pairs[i][1] + 'px';
      img.style.position = 'absolute';
      img.style.top = positions[positions.length - 1][1] + 'px';
      img.style.left = positions[positions.length - 1][0] + 'px';
      img.loading = 'lazy';
      container.appendChild(img);

      i++;
      if (i == key_values.length) {
        clearInterval(interval);
      }
    }, 100);
  </script>
</Base>

<style>
  #container {
    position: relative;
    width: 100%;
    min-height: 80vh;
    padding: 10px;
  }
  #container img {
    display: block;
  }
</style>
